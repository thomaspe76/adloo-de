---
interface Props {
  title: string;
  slug: string;
  image: string;
  category: string;
  date?: string;
}

const { title, slug, image, category, date } = Astro.props;
---

<a href={`/news/${slug}`} class="group block relative overflow-hidden rounded-lg aspect-[3/4] md:aspect-[3/4] sm:aspect-[16/9]">
  <img
    src={image}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent transition-opacity duration-500"></div>

  <!-- Category badge -->
  <span class="absolute top-4 left-4 bg-white text-dark text-xs font-medium px-3 py-1.5 rounded">
    {category}
  </span>

  <!-- Title -->
  <div class="absolute bottom-0 left-0 right-0 p-6">
    <h3 class="text-white font-bold text-lg leading-snug transition-transform duration-500 translate-y-2 group-hover:translate-y-0">
      {title}
    </h3>
    {date && (
      <p class="text-white/70 text-sm mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
        {date}
      </p>
    )}
  </div>
</a>
