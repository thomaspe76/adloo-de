---
interface Props {
  title: string;
  slug: string;
  image: string;
  category: string;
  date?: Date;
}

const { title, slug, image, category, date } = Astro.props;
const formattedDate = date
  ? date.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' })
  : '';
---

<a href={`/news/${slug}`} class="group block relative overflow-hidden rounded-lg aspect-[3/4] md:aspect-[3/4] sm:aspect-[16/9]">
  <img
    src={image}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

  <!-- Category badge -->
  <span class="absolute top-4 left-4 bg-white text-dark text-xs font-medium px-3 py-1.5 rounded z-10">
    {category}
  </span>

  <!-- Default title (visible, hides on hover) -->
  <div class="absolute bottom-0 left-0 right-0 p-6 transition-opacity duration-300 group-hover:opacity-0">
    <h3 class="text-white font-bold text-lg leading-snug">
      {title}
    </h3>
  </div>

  <!-- Hover overlay (red, slides up) -->
  <div class="absolute bottom-0 left-0 right-0 bg-primary p-6 translate-y-full group-hover:translate-y-0 transition-transform duration-400 ease-out">
    <h3 class="text-white font-bold text-lg leading-snug mb-3">
      {title}
    </h3>
    <div class="flex items-center justify-between">
      {formattedDate && (
        <span class="text-white/90 text-sm">{formattedDate}</span>
      )}
      <span class="w-10 h-10 flex items-center justify-center rounded-full border-2 border-white text-white ml-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
