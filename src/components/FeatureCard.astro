---
interface Props {
  title: string;
  body: string;
  bullets: string[];
  image: string;
  imageAlt: string;
  tagline: string;
}

const { title, body, bullets, image, imageAlt, tagline } = Astro.props;
---

<div class="border-l border-gray-300 pl-6 md:pl-8 py-2 space-y-5">
  <h3 class="text-2xl md:text-3xl font-bold text-dark">{title}</h3>
  <p class="text-base font-bold text-gray-700 leading-relaxed">{body}</p>
  <ul class="space-y-2">
    {bullets.map(item => (
      <li class="flex items-start gap-2 text-sm text-gray-700">
        <span class="text-primary mt-0.5 flex-shrink-0">&#x2022;</span>
        {item}
      </li>
    ))}
  </ul>
  <div class="pt-2">
    <img
      src={image}
      alt={imageAlt}
      class="w-full rounded-lg object-cover aspect-[3/2]"
      loading="lazy"
    />
  </div>
  <p class="text-sm italic text-gray-500">{tagline}</p>
</div>
