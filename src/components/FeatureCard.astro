---
interface Props {
  title: string;
  body: string;
  bullets: string[];
  image: string;
  imageAlt: string;
  tagline: string;
  layout: 'text-left' | 'image-left';
}

const { title, body, bullets, image, imageAlt, tagline, layout } = Astro.props;
const isImageLeft = layout === 'image-left';
---

<div class="bg-gray-100 rounded-lg overflow-hidden">
  <div class:list={[
    'grid grid-cols-1 md:grid-cols-2 gap-0',
    isImageLeft && 'md:[&>*:first-child]:order-2 md:[&>*:last-child]:order-1',
  ]}>
    <!-- Text Column -->
    <div class="p-8 md:p-12 lg:p-16 flex flex-col justify-center">
      <h3 class="text-2xl md:text-3xl font-bold text-dark mb-6">{title}</h3>
      <p class="text-gray-700 leading-relaxed mb-6">{body}</p>
      <div class="space-y-2">
        {bullets.map(item => (
          <p class="text-gray-700">– {item}</p>
        ))}
      </div>
    </div>

    <!-- Image Column with Quote Box -->
    <div class="relative">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover aspect-[4/3] md:aspect-auto md:min-h-[400px]"
        loading="lazy"
      />
      <!-- Quote box overlapping image -->
      <div class:list={[
        'absolute bottom-6 bg-white p-6 md:p-8 rounded-sm shadow-sm max-w-[85%]',
        isImageLeft ? 'right-6 left-auto' : 'left-6 right-auto',
      ]}>
        <div class="flex gap-3 items-start">
          <span class="text-xl font-bold text-dark leading-none mt-0.5">"</span>
          <p class="text-sm md:text-base font-bold text-dark leading-snug">{tagline}</p>
        </div>
      </div>
    </div>
  </div>
</div>
