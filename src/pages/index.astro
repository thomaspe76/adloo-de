---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kassra Adloo | Stadtratskandidat SPD Aschaffenburg">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary to-primary-dark text-white py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">Kassra Adloo</h1>
      <p class="text-xl md:text-2xl mb-8 text-white/90">Für ein lebendiges Aschaffenburg</p>
      <a href="/kommunalwahl-aschaffenburg-2026" class="inline-block bg-white text-primary font-bold px-8 py-3 rounded-lg hover:bg-gray-100 transition-colors">
        Mehr erfahren
      </a>
    </div>
  </section>

  <!-- Schwerpunkte -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">Meine Schwerpunkte</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-light rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold mb-4">Integration & Vielfalt</h3>
        <p class="text-gray">Für ein weltoffenes und vielfältiges Aschaffenburg, in dem alle Menschen willkommen sind.</p>
      </div>
      <div class="bg-light rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold mb-4">Lebendige Innenstadt</h3>
        <p class="text-gray">Für eine attraktive Innenstadt mit starkem Einzelhandel und Gastronomie.</p>
      </div>
      <div class="bg-light rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold mb-4">Klimaschutz</h3>
        <p class="text-gray">Für nachhaltige Stadtentwicklung und aktiven Klimaschutz vor Ort.</p>
      </div>
    </div>
  </section>

  <!-- News Teaser -->
  <section class="bg-light py-20">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Aktuelles</h2>
      <div class="text-center">
        <a href="/news" class="inline-block bg-primary text-white font-bold px-8 py-3 rounded-lg hover:bg-primary-dark transition-colors">
          Alle News ansehen
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
