---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogArchiveCard from '../../components/BlogArchiveCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const formatDate = (date: Date) =>
  date.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title="News | Kassra Adloo" description="Aktuelle Neuigkeiten und Berichte von Kassra Adloo aus Aschaffenburg.">
  <section class="max-w-[72rem] mx-auto px-4 md:px-6 py-12 md:py-20">
    <h1 class="text-3xl md:text-5xl font-bold text-center mb-12">News</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {posts.map(post => (
        <BlogArchiveCard
          title={post.data.title}
          slug={post.id}
          image={post.data.image || '/images/kassra-adloo-logo.webp'}
          category={post.data.category}
          date={formatDate(post.data.date)}
          description={post.data.description}
        />
      ))}
    </div>
  </section>
</BaseLayout>
